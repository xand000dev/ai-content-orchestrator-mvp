# 2. /newbot → задай ім'я → отримай токен виду 7xxxxxxxxx:AAxxxxxxxxx
# 3. Додай бота як АДМІНІСТРАТОРА у свій канал
TELEGRAM_BOT_TOKEN=7xxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
