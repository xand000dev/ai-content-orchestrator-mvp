# ─── OpenRouter ───────────────────────────────────────────────
# Безкоштовний ключ: https://openrouter.ai → Sign in → Keys → Create Key
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Telegram ─────────────────────────────────────────────────
# 1. Відкрий @BotFather в Telegram
# 2. /newbot → задай ім'я → отримай токен виду 7xxxxxxxxx:AAxxxxxxxxx
# 3. Додай бота як АДМІНІСТРАТОРА у свій канал
TELEGRAM_BOT_TOKEN=7xxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID каналу: @username (публічний) або -100xxxxxxxxxx (приватний/числовий)
TELEGRAM_CHANNEL_ID=-1003514711327

# ─── Telegram Bot Control (review прямо в телефоні) ───────────
# Свій Telegram ID (дізнатись: напиши @userinfobot у Telegram)
TELEGRAM_ADMIN_CHAT_ID=
# Увімкнути отримання review-сповіщень з кнопками Схвалити/Відхилити
TELEGRAM_BOT_CONTROL=false

# ─── Obsidian Knowledge Base ──────────────────────────────────
# Шлях до Obsidian vault (папки з нотатками).
# Якщо не вказано — інтеграція вимкнена (все працює без неї).
# Windows:  C:/Users/username/Documents/MyVault
# Mac/Linux: /Users/username/Documents/MyVault
OBSIDIAN_VAULT_PATH=
